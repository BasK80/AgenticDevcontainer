#!/usr/bin/env bash
# Host-side firewall management. Run from the AgenticDevcontainer project root
# on your HOST shell (WSL/macOS) — NOT inside the dev container (development
# can't reach the management plane).
set -euo pipefail
PROJECT="${PROJECT:-$(basename "$PWD")}"
CTRL="claude-${PROJECT}-control"
case "${1:-}" in
  allow)  shift; docker exec "$CTRL" allow "$@" ;;
  deny)   shift; docker exec "$CTRL" deny  "$@" ;;
  blocks) docker exec "$CTRL" show_blocks ;;
  list)   docker exec "$CTRL" list_allows ;;
  log)    docker exec -it "$CTRL" tail_firewall ;;
  web)    echo "http://127.0.0.1:8088" ;;
  *) echo "usage: ./tools/fw allow <domain> [ttl_seconds] | ./tools/fw deny <domain> | ./tools/fw blocks | ./tools/fw list | ./tools/fw log | ./tools/fw web"
     echo "       (override project name with: PROJECT=<name> ./tools/fw ...)" ;;
esac
