{
  // Auto-open an integrated terminal when the workspace folder opens, so users
  // can interact with the container without manually opening a terminal panel.
  // Step 4.1 of FUTURE_IMPROVEMENTS_IMPLEMENTATION_PLAN.md.
  //
  // VS Code prompts to "Allow Automatic Tasks" on first open; once allowed the
  // terminal opens on every subsequent attach. An empty command launches the
  // default shell profile (zsh, set in devcontainer.json) interactively.
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Open terminal on attach",
      "type": "shell",
      "command": "",
      "runOptions": { "runOn": "folderOpen" },
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "focus": true
      },
      "problemMatcher": []
    }
  ]
}
